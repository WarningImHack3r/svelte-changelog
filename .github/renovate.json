{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended", ":disableDependencyDashboard"],
	"labels": ["dependencies"],
	"rangeStrategy": "bump",
	"postUpdateOptions": ["pnpmDedupe"],
	"constraints": {
		"node": ">=26"
	},
	"ignoreDeps": ["node"],
	"minimumReleaseAge": "1 day",
	"packageRules": [
		{
			"matchManagers": ["github-actions", "npm"],
			"groupName": "{{manager}}",
			"addLabels": ["{{manager}}"]
		}
	]
}
